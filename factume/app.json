{
  "expo": {
    "name": "Factu.me",
    "slug": "factume",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.factume.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Factu.me utilise le microphone pour créer des factures vocalement.",
        "NSCameraUsageDescription": "Factu.me utilise la caméra pour prendre en photo votre logo.",
        "NSPhotoLibraryUsageDescription": "Factu.me accède à vos photos pour importer votre logo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.factume.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Factu.me utilise le microphone pour créer des factures vocalement."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Factu.me accède à vos photos pour importer votre logo.",
          "cameraPermission": "Factu.me utilise la caméra pour prendre en photo votre logo."
        }
      ],
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "factume"
  }
}
